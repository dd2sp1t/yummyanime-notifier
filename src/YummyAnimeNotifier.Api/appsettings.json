{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "Sqlite"
  },
  "YummyAnimeSiteData": {
    "Domain": "https://site.yummyani.me",
    "AnimeUpdatesRelativeLink": "/catalog/anime-updates"
  },
  "YummyAnimeClientSettings": {
    "BaseAddress": "https://site.yummyani.me",
    "TimeoutSeconds": 15,
    "MaxRetryCount": 3,
    "CircuitBreakerEventCount": 3,
    "CircuitBreakerDurationSeconds": 15
  },
  "NotificationSettings": {
    "MaxParallelism": 5
  }
}