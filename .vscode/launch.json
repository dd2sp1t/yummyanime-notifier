{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/AniMediaNotifier.Api/bin/Debug/net8.0/AniMediaNotifier.Api.dll",
      "cwd": "${workspaceFolder}/src/AniMediaNotifier.Api",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "stopAtEntry": false
    },
    {
      "name": ".NET Worker",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/AniMediaNotifier.Worker/bin/Debug/net8.0/AniMediaNotifier.Worker.dll",
      "cwd": "${workspaceFolder}/src/AniMediaNotifier.Worker",
      "env": {
        "DOTNET_ENVIRONMENT": "Development"
      },
      "stopAtEntry": false
    }
  ]
}
